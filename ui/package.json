{
  "name": "tuttle-ui",
  "productName": "Tuttle",
  "version": "3.7.2",
  "description": "Cross-platform Electron UI for Tuttle",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "preview": "vite preview",
    "electron:dev": "vite build && electron ."
  },
  "build": {
    "appId": "dev.tuttle.app",
    "productName": "Tuttle",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "electron/preload.cjs"
    ],
    "extraResources": [
      {
        "from": "../dist/tuttle-rpc",
        "to": "tuttle-rpc"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "tuttle-dev",
      "repo": "tuttle",
      "releaseType": "release"
    },
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "zip",
        "dmg",
        "dir"
      ],
      "extendInfo": {
        "NSCalendarsFullAccessUsageDescription": "Tuttle needs access to your calendars to import events for time tracking."
      }
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": ["AppImage", "deb", "rpm"],
      "category": "Office"
    },
    "deb": {
      "depends": ["zlib1g", "libfuse2"]
    },
    "rpm": {
      "depends": ["zlib", "fuse2-libs"]
    }
  },
  "dependencies": {
    "electron-updater": "^6.6.2",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.3"
  },
  "allowScripts": {
    "electron": true
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "electron": "^36.2.1",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.5",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
